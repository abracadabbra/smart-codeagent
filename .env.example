# LLM API Key（Anthropic 兼容协议 / SenseNova 默认）
# 获取: https://token.sensenova.cn/console/token
LLM_API_KEY=sk-your-sensenova-key-here

# Optional: Provider base URL override（默认 SenseNova）
# LLM_BASE_URL=https://token.sensenova.cn

# Optional: Model override（默认 deepseek-v4-flash）
# 可选模型（SenseNova 控制台）：sensenova-6.7-flash-lite | deepseek-v4-flash | glm-5.2
# LLM_MODEL=deepseek-v4-flash