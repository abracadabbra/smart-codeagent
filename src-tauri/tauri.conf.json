{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart CodeAgent",
  "version": "0.1.0",
  "identifier": "com.shentao.smartcodeagent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Smart CodeAgent",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2M0U4Qjg0Njc3Qjc3M0MKUldROGQzdG5oSXMrbG9ZTTJQVFk4UEVOY3NtSXRzNzRleERrWkxBM0ErZUxDVFlpcFBVeTAyVkYK",
      "endpoints": [
        "https://github.com/abracadabbra/smart-codeagent/releases/latest/download/latest.json"
      ]
    }
  }
}