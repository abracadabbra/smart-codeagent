{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart CodeAgent",
  "version": "0.1.0",
  "identifier": "com.shentao.smartcodeagent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Smart CodeAgent",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4RUUyM0YxQ0UxNjMxMTIKUldRU01SYk84U1B1eURKOE5zSFBnUmVsQWYvS05XOGFDVmh4c0x0TlBlNkN6Wlhmdnh5NU5XT2gK",
      "endpoints": [
        "https://github.com/abracadabbra/smart-codeagent/releases/latest/download/latest.json"
      ]
    }
  }
}